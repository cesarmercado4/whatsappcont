<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= appName %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="/public/css/styles.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
    <div class="container">
      <span class="navbar-brand fw-semibold"><%= appName %></span>
      <span class="navbar-text text-white-50 small">Metricas de conversaciones entrantes</span>
    </div>
  </nav>

  <main class="container my-4">
    <header class="mb-4">
      <h1 class="h3 mb-1">Dashboard de conversaciones</h1>
      <p class="text-muted mb-0">
        Conversacion unica = combinacion <code>telefono + fecha</code>.
      </p>
    </header>

    <section class="row g-3 mb-4">
      <div class="col-sm-6 col-lg-4">
        <div class="card metric-card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="metric-label">Conversaciones hoy</div>
            <div id="metric-hoy" class="metric-value">0</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-4">
        <div class="card metric-card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="metric-label">Conversaciones este mes</div>
            <div id="metric-mes" class="metric-value">0</div>
          </div>
        </div>
      </div>
      <div class="col-sm-6 col-lg-4">
        <div class="card metric-card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="metric-label">Conversaciones este anio</div>
            <div id="metric-anio" class="metric-value">0</div>
          </div>
        </div>
      </div>
    </section>

    <section class="row g-3 mb-4">
      <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Conversaciones por dia</div>
          <div class="card-body">
            <canvas id="dailyChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-xl-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Conversaciones por mes</div>
          <div class="card-body">
            <canvas id="monthlyChart"></canvas>
          </div>
        </div>
      </div>
    </section>

    <section class="row g-3 mb-4">
      <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Conversaciones por opcion (historico)</div>
          <div class="card-body">
            <canvas id="optionsChart"></canvas>
          </div>
        </div>
      </div>
      <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-header bg-white fw-semibold">Resumen por opcion</div>
          <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-light">
                <tr>
                  <th>Codigo</th>
                  <th>Opcion</th>
                  <th>Conversaciones</th>
                </tr>
              </thead>
              <tbody id="options-table-body">
                <tr>
                  <td colspan="3" class="text-center text-muted py-3">Sin datos aun.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>

    <section class="row g-3">
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Resumen diario</div>
          <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-light">
                <tr>
                  <th>Fecha</th>
                  <th>Conversaciones</th>
                </tr>
              </thead>
              <tbody id="daily-table-body">
                <tr>
                  <td colspan="2" class="text-center text-muted py-3">Sin datos aun.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white fw-semibold">Resumen mensual</div>
          <div class="table-responsive">
            <table class="table table-sm table-striped mb-0">
              <thead class="table-light">
                <tr>
                  <th>Anio</th>
                  <th>Mes</th>
                  <th>Conversaciones</th>
                </tr>
              </thead>
              <tbody id="monthly-table-body">
                <tr>
                  <td colspan="3" class="text-center text-muted py-3">Sin datos aun.</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="/public/js/dashboard.js"></script>
</body>
</html>
